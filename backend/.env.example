# ── Daily Work System — Go backend ──
# คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจริง (อย่า commit .env)

# พอร์ตที่เซิร์ฟเวอร์ฟัง
PORT=8080

# origin ของ frontend (Next.js) — คั่นด้วย comma ได้
CORS_ORIGINS=http://localhost:3000

# Postgres ของ Supabase
#   Dashboard > Project Settings > Database > Connection string > URI
#   แนะนำใช้ connection pooler (พอร์ต 6543) และเติม ?sslmode=require
DATABASE_URL=postgresql://postgres.<ref>:<db-password>@aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require

# ใช้ verify access token ของ Supabase (HS256)
#   Dashboard > Project Settings > API > JWT Settings > JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ใช้เรียก GoTrue Admin API (จัดการผู้ใช้) — ฝั่ง server เท่านั้น
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
