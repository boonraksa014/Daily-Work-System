# คัดลอกไฟล์นี้เป็น .env.local แล้วใส่ค่าจาก Supabase
# (Supabase Dashboard > Project Settings > Data API / API Keys)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# service_role key — ฝั่งเซิร์ฟเวอร์เท่านั้น (ใช้สร้าง/จัดการบัญชีในเมนูผู้ใช้งาน)
# ห้ามขึ้นต้นด้วย NEXT_PUBLIC และห้ามเปิดเผย
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# URL ของ Go backend (data layer) — ดู backend/README.md
NEXT_PUBLIC_API_URL=http://localhost:8080
